<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/mapmytasksbackround"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Productivity Insights"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"/>

        <Spinner
            android:id="@+id/categorySpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/white"
            android:layout_marginBottom="32dp"/>

        <TextView android:text="Morning" android:textColor="@color/black" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <ProgressBar
            android:id="@+id/progressMorning"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:progress="30"
            android:progressTint="@color/pastel_blue"
            android:progressBackgroundTint="@color/pastel_grey"/>
        <TextView android:id="@+id/tvMorningPercent" android:text="30%" android:textColor="@color/black" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="16dp"/>

        <TextView android:text="Afternoon" android:textColor="@color/black" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <ProgressBar
            android:id="@+id/progressAfternoon"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:progress="55"
            android:progressTint="@color/pastel_mint"
            android:progressBackgroundTint="@color/pastel_grey"/>
        <TextView android:id="@+id/tvAfternoonPercent" android:text="55%" android:textColor="@color/black" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="16dp"/>

        <TextView android:text="Evening" android:textColor="@color/black" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <ProgressBar
            android:id="@+id/progressEvening"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:progress="15"
            android:progressTint="@color/pastel_rose"
            android:progressBackgroundTint="@color/pastel_grey"/>
        <TextView android:id="@+id/tvEveningPercent" android:text="15%" android:textColor="@color/black" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="16dp"/>

        <TextView android:text="Night" android:textColor="@color/black" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <ProgressBar
            android:id="@+id/progressNight"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:progress="10"
            android:progressTint="@color/pastel_blue"
            android:progressBackgroundTint="@color/pastel_grey"/>
        <TextView android:id="@+id/tvNightPercent" android:text="10%" android:textColor="@color/black" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Back"
            android:backgroundTint="@color/pastel_grey"
            android:textColor="@color/black"
            android:textAllCaps="false"
            android:textStyle="bold"/>

    </LinearLayout>
</ScrollView>